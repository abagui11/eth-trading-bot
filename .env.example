ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
TELEGRAM_BOT_TOKEN=
# Paywall off by default — anyone who /start's gets access. Set true to restrict.
PAYWALL_ENABLED=false
# Required only when PAYWALL_ENABLED=true
ALLOWED_TELEGRAM_IDS=
# Optional: legacy channel or admin monitoring
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=
# Audit alerts for rationale / chat hallucinations (private group recommended)
MONITOR_CHAT_ID=
# Macro headline RSS feeds (comma-separated). Defaults: CNBC top news + CoinDesk if unset.
# MACRO_FEED_URLS=https://search.cnbc.com/rs/search/combinedcms/view.xml?partnerId=wrss01&id=100003114,https://www.coindesk.com/arc/outboundfeeds/rss/
# Optional extra T2 keywords (+20 score), e.g. fusaka
# MACRO_KEYWORD_EXTRA=
# Bearer token for POST /api/macro/ingest on dashboard
# MACRO_WEBHOOK_SECRET=
MARKET_DATA_API=https://api.coinbase.com/api/v3/brokerage/market
PORTFOLIO_VALUE=5000
PAPER_PORTFOLIO_VALUE=5000
# Public HTTPS URL for Agent journal + My book magic links (no trailing slash)
# DASHBOARD_PUBLIC_URL=https://dashboard.yourdomain.com
DASHBOARD_PORT=8080
# Optional HMAC secret for /me links (defaults to TELEGRAM_BOT_TOKEN)
# ME_TOKEN_SECRET=
# ME_TOKEN_TTL_SEC=3600
# ME_SESSION_TTL_SEC=86400
